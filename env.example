# Copie ce fichier en .env et remplis les valeurs

# Token de ton bot (obtenu via @BotFather sur Telegram)
TELEGRAM_TOKEN=TON_TOKEN_ICI

# Ton Chat ID (obtenu via @userinfobot sur Telegram)
CHAT_ID=TON_CHAT_ID_ICI

# Clés API Groq séparées par des virgules (console.groq.com)
GROQ_KEYS=gsk_cle1,gsk_cle2,gsk_cle3

# Heure du scan automatique (format 24h, heure française)
SCAN_HOUR=9

# Bankroll de départ en euros
BANKROLL=100
